    def update_app(self):
        self.add_log("Checking for updates from GitHub...")
        threading.Thread(target=self._perform_update, daemon=True).start()

    def _perform_update(self):
        url = "https://raw.githubusercontent.com/PXG4E/ROBLOXMANAGER/refs/heads/main/UPDATE"
        try:
            res = requests.get(url, timeout=10)
            if res.status_code == 200:
                new_code = res.text
                if len(new_code.strip()) > 100: 
                    current_file = os.path.abspath(__file__)
                    with open(current_file, "w", encoding="utf-8") as f:
                        f.write(new_code)
                    
                    self.add_log("✅ Update applied successfully!")
                    self.add_log("Restarting application in 3 seconds...")
                    time.sleep(3)
                    os.execl(sys.executable, sys.executable, *sys.argv)
                else:
                    self.add_log("❌ Update file is too small or invalid. Aborting.")
            else:
                self.add_log(f"❌ Failed to fetch update (HTTP Status: {res.status_code})")
        except Exception as e:
            self.add_log(f"❌ Error during update: {str(e)}")
            
