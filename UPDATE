        self.btn_power = ctk.CTkButton(self.action_frame, text="OFF", width=50, height=30, fg_color=RED, font=(FONT_NAME, 11, "bold"), command=self.toggle_power)
        self.btn_power.pack(side="left", padx=2)
        ctk.CTkButton(self.action_frame, text="KILL", width=50, height=30, fg_color=RED, text_color="white", font=(FONT_NAME, 11, "bold"), command=self.kill_proc).pack(side="left", padx=2)
        ctk.CTkButton(self.action_frame, text="DEL", width=50, height=30, fg_color=CYAN, text_color="black", font=(FONT_NAME, 11, "bold"),
                      command=self.remove_me).pack(side="left", padx=2)

        self.update_method_ui()

    def toggle_method(self):
        self.join_method = "Private Server" if self.join_method == "Place ID" else "Place ID"
        self.app.add_log(f"⚙️ Mode changed to {self.join_method} for {self.account_name}")
        self.update_method_ui()

    def update_method_ui(self):
        if self.join_method == "Place ID":
            self.btn_method.configure(text="MODE: ID", fg_color=CYAN, text_color="black")
            self.entry_pid.configure(border_color=CYAN)
            self.entry_psl.configure(border_color="#333")
        else:
            self.btn_method.configure(text="MODE: PS", fg_color=PURPLE, text_color="white")
            self.entry_pid.configure(border_color="#333")
            self.entry_psl.configure(border_color=PURPLE)

    def toggle_power(self, force_state=None):
        if force_state is not None:
            self.is_account_on = force_state
        else:
            self.is_account_on = not self.is_account_on
        state_str = "ENABLED" if self.is_account_on else "DISABLED"
        self.app.add_log(f"🔘 Rejoin {state_str} for {self.account_name}")
        self.btn_power.configure(
            text="ON" if self.is_account_on else "OFF",
            fg_color=GREEN if self.is_account_on else RED,
            text_color="black" if self.is_account_on else "white"
        )

    def kill_proc(self):
        if self.pid:
            try:
                psutil.Process(self.pid).kill()
            except Exception:
                pass
            self.app._drop_log_entry(self.pid)
            self.pid = None
        self.app.add_log(f"💀 Force killed process for {self.account_name}")
        self.lbl_event.configure(text="Killed.")

    def remove_me(self):
        self.app.remove_account(self.row_key)

    def _copy_name(self):
        self.clipboard_clear()
        self.clipboard_append(self.account_name)
        self.app.add_log(f"📋 Copied name: {self.account_name}")


