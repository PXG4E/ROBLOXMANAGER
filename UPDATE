    def webhook_worker(self):
        while True:
            try:
                if self.webhook_enabled_var.get():
                    url = self.webhook_url_entry.get().strip()
                    raw_iv = self.webhook_interval_entry.get().strip()
                    interval = int(raw_iv) if (raw_iv.isdigit() and int(raw_iv) > 0) else 30
                    with self.webhook_lock:
                        if self.unsent_logs and url.startswith("http"):
                            batch = "\n".join(self.unsent_logs)
                            if len(batch) > 1900:
                                batch = batch[:1900] + "..."
                            payload = {"embeds": [{"title": "Roblox Manager Updates",
                                                   "description": f"```\n{batch}\n```", "color": 524287}]}
                            requests.post(url, json=payload, timeout=10)
                            self.unsent_logs.clear()
                else:
                    interval = 5
            except Exception:
                interval = 10
            time.sleep(interval)

    def fetch_presence_batch(self):
        uid_cookie_map = {}
        for w in self.accounts.values():
            if w.user_id and w.is_account_on and not w.is_launching:
                uid_cookie_map[w.user_id] = w.cookie

        if not uid_cookie_map:
            return {}

        cookie = next(iter(uid_cookie_map.values()))
        try:
            s = requests.Session()
            s.cookies.set(".ROBLOSECURITY", cookie, domain=".roblox.com")
            r = s.post(
                "https://presence.roblox.com/v1/presence/users",
                json={"userIds": list(uid_cookie_map.keys())},
                timeout=8,
            )
            if r.status_code == 200:
                return {
                    p["userId"]: p.get("userPresenceType", 0)
                    for p in r.json().get("userPresences", [])
                    if "userId" in p
                }
        except Exception:
            pass
        return {}

    def _drop_log_entry(self, pid):
        with self._log_map_lock:
            self.log_map.pop(pid, None)

    def _find_log_file_for_pid(self, pid):
        if not os.path.isdir(self.log_path):
            return None, 0

        with self._log_map_lock:
            claimed = {entry["path"] for entry in self.log_map.values()}

        all_files = []
        seen = set()
        for pattern in ROBLOX_LOG_GLOBS:
            for fpath in glob.glob(os.path.join(self.log_path, pattern)):
                if fpath not in seen:
                    seen.add(fpath)
                    all_files.append(fpath)

        if not all_files:
            return None, 0

        unclaimed = [f for f in all_files if f not in claimed]
        pool = unclaimed if unclaimed else all_files 

        proc_start = None
        try:
            proc_start = psutil.Process(pid).create_time()
        except Exception:
            pass

        if proc_start is not None:
            TIME_WINDOW = 90.0 
            candidates = []
            for fpath in pool:
                try:
                    ctime = os.path.getctime(fpath)
                    delta = abs(ctime - proc_start)
                    if delta <= TIME_WINDOW:
                        candidates.append((delta, fpath))
                except OSError:
                    pass
            if candidates:
                candidates.sort(key=lambda x: x[0])
                return candidates[0][1], 0

            pool_sorted = sorted(pool, key=os.path.getctime, reverse=True)
            for fpath in pool_sorted:
                try:
                    if os.path.getctime(fpath) >= proc_start - 120.0:
                        return fpath, 0
                except OSError:
                    pass

        pool_sorted = sorted(pool, key=os.path.getmtime, reverse=True)
        needle = f"Process ID: {pid}"
        for fpath in pool_sorted[:30]:
            try:
                with open(fpath, 'r', encoding='utf-8', errors='ignore') as f:
                    if needle in f.read(8192):
                        return fpath, 0
            except Exception:
                pass

        return None, 0

    def sync_log_file(self, pid):
        with self._log_map_lock:
            if pid in self.log_map:
                return self.log_map[pid]["path"]

        fpath, offset = self._find_log_file_for_pid(pid)
        if fpath:
            with self._log_map_lock:
                self.log_map[pid] = {"path": fpath, "offset": offset, "joined": False}
        return fpath

    def check_disconnect_in_logs(self, pid):
        with self._log_map_lock:
            entry = self.log_map.get(pid)

        if not entry:
            fpath, offset = self._find_log_file_for_pid(pid)
            if not fpath:
                return None
            entry = {"path": fpath, "offset": offset, "joined": False}
            with self._log_map_lock:
                self.log_map[pid] = entry
            fname = os.path.basename(fpath)
            self.after(0, lambda p=pid, n=fname: self.add_log(f"📄 Log registered for PID {p}: {n}"))

        fpath = entry["path"]
        if not os.path.isfile(fpath):
            self._drop_log_entry(pid)
            return None

        try:
            file_size = os.path.getsize(fpath)
        except OSError:
            return None

        current_offset = entry["offset"]
        if file_size <= current_offset:
            return None

        try:
            with open(fpath, 'r', encoding='utf-8', errors='ignore') as f:
                f.seek(current_offset)
                new_content = f.read()
        except Exception:
            return None

        with self._log_map_lock:
            if pid in self.log_map:
                self.log_map[pid]["offset"] = file_size

        if not new_content:
            return None

        lowered = new_content.lower()

        for pattern in JOIN_CONFIRMED_PATTERNS:
            if pattern in lowered:
                with self._log_map_lock:
                    if pid in self.log_map:
                        self.log_map[pid]["joined"] = True
                break

        for keyword, reason in DISCONNECT_PATTERNS:
            if keyword.lower() in lowered:
                return reason

        return None

    def get_auth_ticket(self, cookie):
        try:
            s = requests.Session()
            s.cookies.set(".ROBLOSECURITY", cookie, domain=".roblox.com")
            h = {
                "User-Agent": "Mozilla/5.0",
                "Referer": "https://www.roblox.com/home",
                "Origin": "https://www.roblox.com",
                "Content-Type": "application/json",
            }
            r = s.post("https://auth.roblox.com/v1/authentication-ticket", headers=h)
            tk = s.post("https://auth.roblox.com/v1/authentication-ticket",
                        headers={**h, "X-CSRF-TOKEN": r.headers.get("X-CSRF-TOKEN")})
            return tk.headers.get("rbx-authentication-ticket")
        except Exception:
            return None

    def launch_roblox(self, w):
        if w.is_launching:
            return False
        w.is_launching = True
        self.add_log(f"🚀 Launching {w.account_name}...")

        ticket = self.get_auth_ticket(w.cookie)
        if not ticket:
            self.add_log(f"❌ Failed to get Auth Ticket for {w.account_name}")
            w.is_launching = False
            return False

        if w.pid:
            self._drop_log_entry(w.pid)
            w.pid = None

        w.rejoin_attempts = 0
        self.after(0, lambda: w.lbl_count.configure(text=f"0/{self.entry_limit.get()}"))

        try:
            old_pids = {p.pid for p in psutil.process_iter(['name']) if "RobloxPlayerBeta" in p.info['name']}
        except Exception:
            old_pids = set()

        if w.join_method == "Private Server":
            link = w.entry_psl.get().strip()
            try:
                lc = re.search(r"privateServerLinkCode=([\w-]+)", link).group(1)
                pid_val = re.search(r"games/(\d+)", link).group(1)
            except AttributeError:
                self.add_log(f"❌ Invalid private server link for {w.account_name}")
                w.is_launching = False
                return False
            lurl = (f"https%3A%2F%2Fassetgame.roblox.com%2Fgame%2FPlaceLauncher.ashx"
                    f"%3Frequest%3DRequestPrivateGame%26browserTrackerId%3D{int(time.time())}"
                    f"%26placeId%3D{pid_val}%26linkCode%3D{lc}")
        else:
            pid_val = w.entry_pid.get().strip()
            lurl = (f"https%3A%2F%2Fassetgame.roblox.com%2Fgame%2FPlaceLauncher.ashx"
                    f"%3Frequest%3DRequestGame%26browserTrackerId%3D{int(time.time())}"
                    f"%26placeId%3D{pid_val}%26isReadOnly%3Dfalse")

        self.close_roblox_handle()
        subprocess.Popen(
            f"start roblox-player:1+launchmode:play+gameinfo:{ticket}+placelauncherurl:{lurl}",
            shell=True,
            creationflags=subprocess.CREATE_NO_WINDOW,
        )

        new_pid = None
        for _ in range(PID_POLL_ATTEMPTS):
            time.sleep(PID_POLL_INTERVAL)
            try:
                current_pids = {p.pid for p in psutil.process_iter(['name']) if "RobloxPlayerBeta" in p.info['name']}
            except Exception:
                continue
            fresh = current_pids - old_pids
            if fresh:
                new_pid = next(iter(fresh))
                break

        if new_pid:
            w.pid = new_pid
            w._last_presence = None
            self.sync_log_file(new_pid)
            self.add_log(f"✅ PID {new_pid} assigned to {w.account_name}")
        else:
            self.add_log(f"⚠️ Could not detect PID for {w.account_name} after launch")

        w.is_launching = False
        return new_pid is not None

