            with open(__file__, "w", encoding="utf-8") as f:
                f.write(r.text)
            os.execl(sys.executable, sys.executable, *sys.argv)

    def toggle_select_all(self):
        for w in self.accounts.values():
            w.check_var.set(self.header_check.get())

    def bulk_enable(self):
        for w in self.accounts.values():
            if w.check_var.get():
                w.toggle_power(True)

    def bulk_disable(self):
        for w in self.accounts.values():
            if w.check_var.get():
                w.toggle_power(False)

    def bulk_delete(self):
        for k in [k for k, w in self.accounts.items() if w.check_var.get()]:
            self.remove_account(k)

    def bulk_set_mode(self, mode):
        for w in self.accounts.values():
            if w.check_var.get():
                w.join_method = mode
                w.update_method_ui()

    def bulk_update_id(self):
        v = self.bulk_id_entry.get()
        for w in self.accounts.values():
            if w.check_var.get():
                w.entry_pid.delete(0, 'end')
                w.entry_pid.insert(0, v)

    def bulk_update_ps(self):
        v = self.bulk_ps_entry.get()
        for w in self.accounts.values():
            if w.check_var.get():
                w.entry_psl.delete(0, 'end')
                w.entry_psl.insert(0, v)

    def add_log(self, msg):
        ts = datetime.now().strftime('%H:%M:%S')
        full_msg = f"[{ts}] {msg}"
        with self.webhook_lock:
            self.unsent_logs.append(full_msg)
        if threading.current_thread() is threading.main_thread():
            self.log_box.insert("end", f"{full_msg}\n")
            self.log_box.see("end")
        else:
            self.after(0, lambda m=full_msg: (
                self.log_box.insert("end", f"{m}\n"),
                self.log_box.see("end"),
            ))

    def clear_logs(self):
        self.log_box.delete("1.0", "end")

    def join_all_accounts(self):
        for w in self.accounts.values():
            threading.Thread(target=self.launch_roblox, args=(w,), daemon=True).start()
            time.sleep(LAUNCH_STAGGER_SECS)

    def kill_all_process(self):
        for w in self.accounts.values():
            w.kill_proc()
        subprocess.run(['taskkill', '/F', '/IM', 'RobloxPlayerBeta.exe'],
                       capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)


