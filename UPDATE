    def kill_all_process(self):
        self.add_log("Attempting to kill all running Roblox processes...")
        for widget in self.accounts.values():
            widget.kill_proc()
        try:
            subprocess.run(['taskkill', '/F', '/IM', 'RobloxPlayerBeta.exe'], capture_output=True)
        except: pass

    def update_all_counts(self, event=None):
        limit = self.entry_limit.get() if self.entry_limit.get().isdigit() else "0"
        for widget in self.accounts.values():
            widget.lbl_count.configure(text=f"{widget.rejoin_attempts}/{limit}")

    def toggle_enable_all(self):
        for widget in self.accounts.values():
            widget.toggle_power(force_state=True)

    def toggle_disable_all(self):
        for widget in self.accounts.values():
            widget.toggle_power(force_state=False)

    def bulk_update_id(self):
        new_id = self.bulk_id_entry.get()
        if not new_id: return
        for widget in self.accounts.values():
            if widget.check_var.get():
                widget.entry_id.delete(0, "end")
                widget.entry_id.insert(0, new_id)

    def bulk_enable(self):
        for widget in self.accounts.values():
            if widget.check_var.get():
                widget.toggle_power(force_state=True)

    def bulk_delete(self):
        to_delete = [name for name, widget in self.accounts.items() if widget.check_var.get()]
        for name in to_delete:
            self.accounts[name].remove_me()
        if not self.accounts:
            self.empty_label.pack(pady=100)

    def close_roblox_handle(self):
        try:
            for proc in psutil.process_iter(['name', 'pid']):
                if "RobloxPlayerBeta" in proc.info['name']:
                    ctypes.windll.kernel32.CreateMutexW(None, True, "ROBLOX_singletonEvent")
        except: pass

    def multi_instance_unlocker(self):
        while True:
            self.close_roblox_handle()
            try: subprocess.run(['taskkill', '/F', '/IM', 'RobloxPlayerLauncher.exe'], capture_output=True)
            except: pass
            time.sleep(0.5)

    def check_disconnect_in_logs(self, pid):
        if not os.path.exists(self.log_path): return False
        try:
            list_of_files = glob.glob(os.path.join(self.log_path, '*Player*'))
            if not list_of_files: return False
            latest_file = max(list_of_files, key=os.path.getctime)
            
            dc_keywords =[
                "same account launched experience from different devices",
                "Connection lost",
                "Internet disconnect",
                "lost connection",
                "Error Code: 264",
                "Error Code: 277",
                "Error Code: 279"
            ]
            
            with open(latest_file, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read().lower()
                for key in dc_keywords:
                    if key.lower() in content:
                        return True
        except: pass
        return False

    def get_auth_ticket(self, cookie):
        try:
            sess = requests.Session()
            sess.cookies.set(".ROBLOSECURITY", cookie, domain=".roblox.com")
            headers = {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
                "Referer": "https://www.roblox.com/home",
                "Origin": "https://www.roblox.com",
                "Content-Type": "application/json"
            }
            res = sess.post("https://auth.roblox.com/v1/authentication-ticket", headers=headers)
            csrf = res.headers.get("X-CSRF-TOKEN")
            if not csrf: return None
            res2 = sess.post("https://auth.roblox.com/v1/authentication-ticket", 
                             headers={**headers, "X-CSRF-TOKEN": csrf})
            return res2.headers.get("rbx-authentication-ticket")
        except: return None

    def launch_roblox(self, widget):
        ticket = self.get_auth_ticket(widget.cookie)
        if not ticket: return False
        place_id = widget.entry_id.get()
        if not place_id: return False
        
        self.close_roblox_handle()
            
        launch_str = f"roblox-player:1+launchmode:play+gameinfo:{ticket}+placelauncherurl:https%3A%2F%2Fassetgame.roblox.com%2Fgame%2FPlaceLauncher.ashx%3Frequest%3DRequestGame%26browserTrackerId%3D{int(time.time())}%26placeId%3D{place_id}%26isReadOnly%3Dfalse"
        subprocess.Popen(f"start {launch_str}", shell=True)
        return True

    def monitor_loop(self):
        while True:
            all_procs = {p.pid: p.name() for p in psutil.process_iter(['name']) if "RobloxPlayerBeta" in p.info['name']}
            limit_val = self.entry_limit.get()
            limit = int(limit_val if limit_val.isdigit() else 0)
            
            for name, widget in self.accounts.items():
                if not widget.is_account_on:
                    widget.lbl_status.configure(text="PAUSED", text_color="gray")
                    widget.status_circle.configure(text_color="gray")
                    widget.lbl_event.configure(text="User Paused.")
                    continue
                
                is_running = False
                if widget.pid and widget.pid in all_procs:
                    is_running = True
                    widget.lbl_event.configure(text="Connected.")
                    if self.check_disconnect_in_logs(widget.pid):
                        self.add_log(f"⚠️ Disconnect detected for {name}. Killing...")
                        widget.lbl_event.configure(text="Disconnect Detected", text_color=RED)
                        widget.kill_proc()
                        is_running = False
                else:
                    for pid, p_name in all_procs.items():
                        if pid not in [w.pid for w in self.accounts.values() if w.pid]:
                            widget.pid = pid
                            is_running = True
                            widget.lbl_event.configure(text="Process attached.")
                            break

                if is_running:
                    widget.lbl_status.configure(text="ONLINE", text_color=GREEN)
                    widget.status_circle.configure(text_color=GREEN)
                else:
                    widget.lbl_status.configure(text="OFFLINE", text_color=RED)
                    widget.status_circle.configure(text_color=RED)
                    
                    if widget.rejoin_attempts < limit:
                        self.add_log(f"🔄 Rejoining {name}...")
                        widget.lbl_event.configure(text="Attempting Rejoin...", text_color=YELLOW)
                        if self.launch_roblox(widget):
                            widget.rejoin_attempts += 1
                            self.update_all_counts()
                            time.sleep(12) 
                        else:
                            self.add_log(f"❌ Failed ticket for {name}")
                            widget.lbl_event.configure(text="Auth Ticket Failed", text_color=RED)
            time.sleep(5)

    def add_account_dialog(self):
        dialog = ctk.CTkInputDialog(text="Enter Nickname:", title="Add Account")
        name = dialog.get_input()
        if name:
            dialog_cookie = ctk.CTkInputDialog(text="Paste .ROBLOSECURITY Cookie:", title="Authentication")
            cookie = dialog_cookie.get_input()
            if cookie:
                if len(self.accounts) == 0:
                    self.empty_label.pack_forget()

                row = AccountRow(self.scroll, name, cookie, "", self)
                row.pack(fill="x", pady=5)
                self.accounts[name] = row
                self.add_log(f"Account '{name}' registered to database.")

    def remove_account(self, name):
        if name in self.accounts: 
            del self.accounts[name]
        self.add_log(f"Account '{name}' deleted.")
        if not self.accounts:
            self.empty_label.pack(pady=100)

if __name__ == "__main__":
    App().mainloop()
