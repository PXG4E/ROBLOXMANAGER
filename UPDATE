    def toggle_power(self, force_state=None):
        if force_state is not None:
            self.is_account_on = force_state
        else:
            self.is_account_on = not self.is_account_on
            
        self.btn_power.configure(text="ON" if self.is_account_on else "OFF", 
                                 fg_color=GREEN if self.is_account_on else RED,
                                 text_color="black" if self.is_account_on else "white")
        if not self.is_account_on: 
            self.kill_proc()

    def kill_proc(self):
        if self.pid:
            try: psutil.Process(self.pid).kill()
            except: pass
            self.pid = None
        self.lbl_event.configure(text="Process killed manually.")

    def remove_me(self):
        self.app.remove_account(self.account_name)
        self.destroy()

