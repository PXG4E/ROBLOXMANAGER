    def monitor_loop(self):
        while True:
            try:
                limit_str = self.entry_limit.get()
                limit = int(limit_str) if limit_str.isdigit() else 0
            except Exception:
                limit = 0

            try:
                all_roblox_pids = {
                    p.pid for p in psutil.process_iter(['name'])
                    if "RobloxPlayerBeta" in p.info['name']
                }
            except Exception:
                all_roblox_pids = set()

            use_presence = self.presence_api_var.get()
            presence_map = self.fetch_presence_batch() if use_presence else {}

            for widget in list(self.accounts.values()):
                if not widget.is_account_on:
                    continue
                if widget.is_launching:
                    self._ui_set_event(widget, "Launching...", CYAN)
                    continue

                pid = widget.pid
                process_alive = pid is not None and pid in all_roblox_pids
                dc_reason = None

                if use_presence and widget.user_id and widget.user_id in presence_map:
                    ptype = presence_map[widget.user_id]
                    prev  = widget._last_presence

                    if ptype == 2:
                        widget._last_presence = 2
                        self._ui_set_online(widget)
                        self._ui_set_event(widget, "In-game", GREEN)
                        if process_alive:
                            dc_reason = self.check_disconnect_in_logs(pid)
                            if not dc_reason:
                                continue  
                        else:
                            continue

                    elif prev == 2 and ptype in (0, 1):
                        widget._last_presence = ptype
                        dc_reason = "Presence lost"

                    else:
                        widget._last_presence = ptype
                        if process_alive:
                            self._ui_set_online(widget, "LOADING")
                            self._ui_set_event(widget, "Joining...", YELLOW)
                            continue
                        else:
                            now = time.time()
                            if now - widget._last_dc_time < DC_COOLDOWN_SECS:
                                self._ui_set_offline(widget)
                                self._ui_set_event(widget, "Launching...", CYAN)
                                continue
                            widget._last_dc_time = now
                            widget.rejoin_attempts += 1
                            self._ui_set_count(widget, widget.rejoin_attempts, limit)
                            if widget.rejoin_attempts <= limit:
                                self.add_log(f"🚀 {widget.account_name} is offline — launching...")
                                self._ui_set_offline(widget)
                                self._ui_set_event(widget, "Launching...", CYAN)
                                threading.Thread(
                                    target=self.launch_roblox,
                                    args=(widget,),
                                    daemon=True,
                                ).start()
                            else:
                                self.add_log(
                                    f"🛑 {widget.account_name} reached retry limit ({limit}). Stopping."
                                )
                                self._ui_set_event(widget, "Limit reached", RED)
                            continue

                elif process_alive and dc_reason is None:
                    dc_reason = self.check_disconnect_in_logs(pid)
                    if not dc_reason:
                        self._ui_set_online(widget)
                        self._ui_set_event(widget, "In-game", GREEN)
                        continue

                elif not process_alive and dc_reason is None:
                    self._ui_set_offline(widget)
                    if pid is not None:
                        self._drop_log_entry(pid)
                        widget.pid = None
                        dc_reason = "Crashed"
                    else:
                        self._ui_set_event(widget, "Standby...")
                        continue

                if dc_reason:
                    now = time.time()
                    if now - widget._last_dc_time < DC_COOLDOWN_SECS:
                        self._ui_set_event(widget, "Rejoining...", YELLOW)
                        continue

                    widget._last_dc_time = now
                    widget.rejoin_attempts += 1
                    self._ui_set_count(widget, widget.rejoin_attempts, limit)
                    self.add_log(
                        f"⚠️ {widget.account_name} disconnected ({dc_reason}). "
                        f"Rejoining [{widget.rejoin_attempts}/{limit}]..."
                    )
                    self._ui_set_event(widget, dc_reason[:22], RED)
                    self._ui_set_offline(widget, "DC")

                    if pid is not None:
                        try:
                            proc = psutil.Process(pid)
                            proc.kill()
                            try:
                                proc.wait(timeout=5)
                            except (psutil.TimeoutExpired, psutil.NoSuchProcess):
                                pass
                        except psutil.NoSuchProcess:
                            pass
                        except Exception:
                            pass
                        self._drop_log_entry(pid)
                        widget.pid = None

                    if widget.rejoin_attempts <= limit:
                        threading.Thread(
                            target=self.launch_roblox,
                            args=(widget,),
                            daemon=True,
                        ).start()
                    else:
                        self.add_log(
                            f"🛑 {widget.account_name} reached retry limit ({limit}). Stopping."
                        )
                        self._ui_set_event(widget, "Limit reached", RED)

            time.sleep(3)

    def close_roblox_handle(self):
        try:
            for p in psutil.process_iter(['name']):
                if "RobloxPlayerBeta" in p.info['name']:
                    ctypes.windll.kernel32.CreateMutexW(None, True, "ROBLOX_singletonEvent")
        except Exception:
            pass

    def multi_instance_unlocker(self):
        while True:
            self.close_roblox_handle()
            subprocess.run(['taskkill', '/F', '/IM', 'RobloxPlayerLauncher.exe'],
                           capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
            time.sleep(0.5)

    def arrange_windows(self):
        if not HAS_WIN32:
            return
        wins = []
        def enum_handler(h, _):
            if win32gui.IsWindowVisible(h):
                text = win32gui.GetWindowText(h)
                if "Roblox" in text and "Manager" not in text:
                    wins.append(h)
        win32gui.EnumWindows(enum_handler, None)
        sw, size = win32api.GetSystemMetrics(0), 188
        cols = sw // size
        for i, h in enumerate(wins):
            win32gui.SetWindowPos(h, win32con.HWND_TOP, (i % cols) * size, (i // cols) * size,
                                  size, size, win32con.SWP_SHOWWINDOW)

    def save_config(self, m=None):
        accs = [{"name": w.lbl_name.cget("text"), "cookie": w.cookie,
                 "pid": w.entry_pid.get(), "psl": w.entry_psl.get(),
                 "mode": w.join_method} for w in self.accounts.values()]
        full_config = {
            "accounts": accs,
            "webhook_url": self.webhook_url_entry.get(),
            "webhook_interval": self.webhook_interval_entry.get(),
            "webhook_enabled": self.webhook_enabled_var.get(),
            "presence_api_enabled": self.presence_api_var.get(),
        }
        with open(m if m else self.config_file, "w") as f:
            json.dump(full_config, f, indent=4)
        self.add_log("💾 Saved.")

    def load_config(self, m=None):
        f = m if m else self.config_file
        if not os.path.exists(f):
            return
        with open(f, "r") as r:
            data = json.load(r)
        if isinstance(data, dict):
            acc_list = data.get("accounts", [])
            self.webhook_url_entry.insert(0, data.get("webhook_url", ""))
            self.webhook_interval_entry.insert(0, data.get("webhook_interval", ""))
            self.webhook_enabled_var.set(data.get("webhook_enabled", False))
            self.presence_api_var.set(data.get("presence_api_enabled", True))
        else:
            acc_list = data
        for i in acc_list:
            row = self._create_row(i.get("name", "..."), i["cookie"], self.placeholder_avatar,
                                   i.get("pid", ""), i.get("psl", ""), i.get("mode", "Place ID"))
            threading.Thread(target=self.async_load_data, args=(row,), daemon=True).start()

    def async_load_data(self, row_obj):
        try:
            h = {"Cookie": f".ROBLOSECURITY={row_obj.cookie}"}
            res = requests.get("https://users.roblox.com/v1/users/authenticated", headers=h, timeout=5)
            if res.status_code == 200:
                uid, name = res.json()["id"], res.json()["name"]
                row_obj.user_id = uid
                tr = requests.get(
                    f"https://thumbnails.roblox.com/v1/users/avatar-headshot"
                    f"?userIds={uid}&size=48x48&format=Png&isCircular=true",
                    timeout=5,
                )
                img_data = requests.get(tr.json()["data"][0]["imageUrl"], timeout=5).content
                new_img = ctk.CTkImage(Image.open(io.BytesIO(img_data)), size=(32, 32))
                self.after(0, lambda: self._update_row_ui(row_obj, name, new_img))
        except Exception:
            pass

    def _update_row_ui(self, row, name, img):
        row.lbl_name.configure(text=name)
        row.img_label.configure(image=img)
        row.account_name = name

    def bulk_add_dialog(self):
        pop = ctk.CTkToplevel(self)
        pop.title("Bulk Paste")
        pop.geometry("500x450")
        pop.attributes('-topmost', True)
        ctk.CTkLabel(pop, text="Paste cookies here:").pack(pady=10)
        box = ctk.CTkTextbox(pop, width=450, height=300, fg_color="#0D0D0D")
        box.pack(padx=20)
        def process():
            raw = box.get("1.0", "end").strip()
            cookies = [c.strip() for c in raw.split("\n") if len(c.strip()) > 100]
            pop.destroy()
            for c in cookies:
                row = self._create_row("Loading...", c, self.placeholder_avatar)
                threading.Thread(target=self.async_load_data, args=(row,), daemon=True).start()
        ctk.CTkButton(pop, text="ADD ALL", command=process).pack(pady=15)

    def _create_row(self, name, cookie, img, pid="", psl="", mode="Place ID"):
        if not self.accounts:
            self.empty_label.pack_forget()
        row = AccountRow(self.scroll, name, cookie, pid, psl, img, self, mode=mode)
        row.pack(fill="x", pady=5)
        key = str(time.time()) + name
        row.row_key = key
        self.accounts[key] = row
        return row

    def remove_account(self, key):
        if key in self.accounts:
            widget = self.accounts[key]
            if widget.pid:
                self._drop_log_entry(widget.pid)
            widget.destroy()
            del self.accounts[key]
            if not self.accounts:
                self.empty_label.pack(pady=100)

